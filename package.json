{
	"name": "@snowdrive/logger",
	"version": "1.0.3",
	"author": "Luciano Morales",
	"license": "MIT",
	"description": "Decorador de TypeScript para automatizar logs y trazar ejecución en métodos y clases.",
	"keywords": [
		"logger",
		"decorator",
		"typescript",
		"tracing"
	],
	"publishConfig": {
		"access": "public",
		"tag": "latest"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/luc-mo/logger.git"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"scripts": {
		"example:express": "tsx watch ./examples/express.ts",
		"example:nestjs": "tsx watch ./examples/nestjs.ts",
		"example:winston": "tsx watch ./examples/winston.ts",
		"build": "tsup",
		"lint": "biome check . --write",
		"format": "biome format --write .",
		"lint:check": "biome check .",
		"format:check": "biome format ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@nestjs/common": "11.1.17",
		"@nestjs/core": "11.1.17",
		"@nestjs/platform-express": "11.1.17",
		"@snowdrive/biome-config": "1.0.0",
		"@types/express": "5.0.6",
		"@types/node": "25.3.2",
		"express": "5.2.1",
		"reflect-metadata": "0.2.2",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "5.9.3",
		"winston": "3.19.0"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	}
}
